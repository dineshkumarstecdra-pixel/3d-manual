{
  "main": "electron-main.cjs",
"build": {
  "appId": "com.tecdra.3dmanual",
  "productName": "Tecdra 3D Manual",
  "directories": {
    "output": "release"
  },
   "win": {
    "target": "nsis",
    "icon": "build/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "build/icon.ico",
    "uninstallerIcon": "build/icon.ico",
    "installerHeaderIcon": "build/icon.ico",
    "shortcutName": "3D Manual"
  }
},
  "name": "my-3d-manual",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
  "dev": "vite",
  "build": "vite build",
  "preview": "vite preview",
  "upload-server": "node server.js",
  "desktop": "electron .",
  "desktop:build": "electron-builder --win --x64"
},
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "vite": "^8.0.0-beta.13"
  },
  "overrides": {
    "vite": "^8.0.0-beta.13"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "dxf-parser": "^1.1.2",
    "express": "^5.2.1",
    "firebase": "^12.9.0",
    "mongodb": "^7.2.0",
    "multer": "^2.1.1",
    "three": "^0.181.2"
  },
  "description": "",
  "main": "electron-main.cjs",
  "keywords": [],
